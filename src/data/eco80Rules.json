{
  "_meta": {
    "version": "1.0.0",
    "product": "Danfoss ECO80 Directional Valve Group",
    "description": "Configuration rules for ValveBuilderMP wizard. Two paths split at Load Sense (LS) question.",
    "paths": ["standard", "load_sense"],
    "maxSections": 12
  },

  "questions": {
    "Q_LS": {
      "id": "Q_LS",
      "label": "Do you require Load Sense functionality?",
      "type": "single_select",
      "options": [
        { "value": "no",  "label": "No – Fixed displacement pump (Open Center)" },
        { "value": "yes", "label": "Yes – Variable displacement pump (Closed Center / LS)" }
      ],
      "next": {
        "no":  "Q_SOLENOID",
        "yes": "Q_LS_SOLENOID"
      }
    },

    "Q_SOLENOID": {
      "id": "Q_SOLENOID",
      "label": "Do your work sections require solenoid (electro-hydraulic) actuation?",
      "hint": "PPRV (Pilot Pressure Reducer Valve) is required for any solenoid actuator.",
      "type": "single_select",
      "path": "standard",
      "options": [
        { "value": "no",  "label": "No – Mechanical actuation only" },
        { "value": "yes", "label": "Yes – Solenoid / electro-hydraulic actuation required" }
      ],
      "next": {
        "no":  "Q_EVPX",
        "yes": "Q_EVPX"
      }
    },

    "Q_EVPX": {
      "id": "Q_EVPX",
      "label": "Do you need electric unloading of the pump (EVPX)?",
      "hint": "EVPX is an electric unload valve. Only available on Open Center with PPRV.",
      "type": "single_select",
      "path": "standard",
      "options": [
        { "value": "no",  "label": "No" },
        { "value": "yes", "label": "Yes – Electric unload valve (EVPX)" }
      ],
      "next": {
        "no":  "Q_NUM_SECTIONS",
        "yes": "Q_EVPX_VOLTAGE"
      }
    },

    "Q_EVPX_VOLTAGE": {
      "id": "Q_EVPX_VOLTAGE",
      "label": "Select EVPX coil voltage",
      "type": "single_select",
      "path": "standard",
      "options": [
        { "value": "12v", "label": "12 Vcc" },
        { "value": "24v", "label": "24 Vcc" }
      ],
      "next": {
        "12v": "Q_NUM_SECTIONS",
        "24v": "Q_NUM_SECTIONS"
      }
    },

    "Q_LS_SOLENOID": {
      "id": "Q_LS_SOLENOID",
      "label": "Do your work sections require solenoid (electro-hydraulic) actuation?",
      "hint": "PPRV is required for solenoid actuation. Closed Center EVP includes PPRV.",
      "type": "single_select",
      "path": "load_sense",
      "options": [
        { "value": "no",  "label": "No – Mechanical actuation only" },
        { "value": "yes", "label": "Yes – Solenoid / electro-hydraulic actuation" }
      ],
      "next": {
        "no":  "Q_LS_NUM_SECTIONS",
        "yes": "Q_LS_NUM_SECTIONS"
      }
    },

    "Q_NUM_SECTIONS": {
      "id": "Q_NUM_SECTIONS",
      "label": "How many work sections (EVB) do you need?",
      "hint": "Maximum 12 sections. Each section is one directional control circuit.",
      "type": "number_input",
      "path": "standard",
      "min": 1,
      "max": 12,
      "next": "Q_BODY_TYPE"
    },

    "Q_LS_NUM_SECTIONS": {
      "id": "Q_LS_NUM_SECTIONS",
