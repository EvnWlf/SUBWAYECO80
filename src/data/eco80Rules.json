  "validation_rules": [
    {
      "rule_id": "VR_01",
      "description": "PVLP/PVLA requires medium body EVB",
      "condition": "pvlp !== 'none'",
      "requires": "evb_body === 'medium'",
      "error": "Shock/anti-cavitation valves require a medium body work section (EVB)."
    },
    {
      "rule_id": "VR_02",
      "description": "EVPX only available with Open Center EVP and PPRV",
      "condition": "evpx === true",
      "requires": "evp_center === 'open' && evp_pprv === true",
      "error": "EVPX requires Open Center EVP with PPRV. Not compatible with Load Sense path."
    },
    {
      "rule_id": "VR_03",
      "description": "EH actuation requires PPRV in EVP",
      "condition": "actuation_type in ['eh_prop','eh_onoff','hydraulic']",
      "requires": "evp_pprv === true",
      "error": "Electro-hydraulic or hydraulic actuation requires PPRV in the pump inlet module (EVP)."
    },
    {
      "rule_id": "VR_04",
      "description": "EH actuation requires electro-hydraulic EVB body",
      "condition": "actuation_type in ['eh_prop','eh_onoff']",
      "requires": "evb_actuation_type === 'electrohydraulic'",
      "error": "EVHC/EVHCO actuators require an electro-hydraulic work section body (EVB)."
    },
    {
      "rule_id": "VR_05",
      "description": "Number of sections must be between 1 and 12",
      "condition": "always",
      "requires": "num_sections >= 1 && num_sections <= 12",
      "error": "ECO80 supports 1 to 12 work sections."
    },
    {
      "rule_id": "VR_06",
      "description": "Spool center must be closed or restricted for Load Sense path",
      "condition": "path === 'load_sense'",
      "requires": "spool_center in ['closed','restricted','closed_3w']",
      "warning": "Open center spools are unusual in Load Sense systems. Verify your application requirement."
    }
  ]
}